generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Bookmark {
  id            String    @id @default(cuid())
  tweetId       String    @unique
  text          String
  authorHandle  String
  authorName    String
  tweetCreatedAt DateTime?
  importedAt    DateTime  @default(now())
  rawJson       String    // full JSON stored as string
  semanticTags    String?   // JSON array of AI-generated searchable tags
  entities        String?   // JSON: {hashtags[], urls[], mentions[], tools[], tweetType}
  enrichedAt      DateTime? // when AI enrichment last ran — drives incremental processing
  enrichmentMeta  String?   // JSON: {sentiment, people[], companies[]} from batch enrichment
  source          String    @default("bookmark")  // "bookmark" | "like"
  repoMeta        String?   // JSON: {fullName, stars, description, lastPush, isArchived, topics[]}
  highlights      String?   // JSON: [{id, text, note, createdAt}]
  readingStatus   String?   // "queue" | "reading" | "done"
  queuedAt        DateTime?
  reminderAt      DateTime?
  reminderNote    String?
  embeddingVec    String?   // JSON float[] for similarity search
  threadData      String?   // JSON: reconstructed thread tweets array
  mediaItems    MediaItem[]
  categories    BookmarkCategory[]
  collections   BookmarkCollection[]

  @@index([authorHandle])
  @@index([tweetCreatedAt])
  @@index([enrichedAt])
  @@index([source])
  @@index([readingStatus])
  @@index([reminderAt])
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  color       String   @default("#6366f1")
  description String?
  isAiGenerated Boolean @default(false)
  createdAt   DateTime @default(now())
  bookmarks   BookmarkCategory[]
}

model BookmarkCategory {
  bookmarkId  String
  categoryId  String
  confidence  Float    @default(1.0)
  bookmark    Bookmark @relation(fields: [bookmarkId], references: [id], onDelete: Cascade)
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([bookmarkId, categoryId])
}

model MediaItem {
  id           String   @id @default(cuid())
  bookmarkId   String
  type         String   // photo | video | gif
  url          String
  thumbnailUrl String?
  localPath    String?
  imageTags    String?  // AI-generated structured JSON visual description
  bookmark     Bookmark @relation(fields: [bookmarkId], references: [id], onDelete: Cascade)

  @@index([bookmarkId])
  @@index([url])
}

model ImportJob {
  id             String   @id @default(cuid())
  filename       String
  status         String   @default("pending") // pending | processing | done | error
  totalCount     Int      @default(0)
  processedCount Int      @default(0)
  errorMessage   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Setting {
  key   String @id
  value String
}

model Collection {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String   @default("#6366f1")
  emoji       String   @default("📁")
  createdAt   DateTime @default(now())
  bookmarks   BookmarkCollection[]
  shared      SharedCollection?
}

model SharedCollection {
  id           String     @id @default(cuid())
  collectionId String     @unique
  slug         String     @unique
  views        Int        @default(0)
  createdAt    DateTime   @default(now())
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
}

model Digest {
  id          String   @id @default(cuid())
  content     String   // JSON: full digest structure
  generatedAt DateTime @default(now())
  periodStart DateTime
  periodEnd   DateTime
}

model BookmarkCollection {
  bookmarkId   String
  collectionId String
  addedAt      DateTime @default(now())
  bookmark     Bookmark   @relation(fields: [bookmarkId], references: [id], onDelete: Cascade)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([bookmarkId, collectionId])
  @@index([collectionId])
}
