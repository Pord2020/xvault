# ─────────────────────────────────────────────────────────────────────
# XVault — Environment Variables
# Copy this file to .env.local and fill in your values.
# ─────────────────────────────────────────────────────────────────────

# ── Database (Supabase / PostgreSQL) ─────────────────────────────────
# Supabase → Project Settings → Database → Connection string (Transaction Pooler)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase → Project Settings → Database → Connection string (Direct)
# Used only for migrations (prisma db push / prisma migrate)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# ── Anthropic / Claude ───────────────────────────────────────────────
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ── OpenAI (opcional) ────────────────────────────────────────────────
# OPENAI_API_KEY=sk-your-key-here

# ── X OAuth (opcional, para importación en vivo) ─────────────────────
# X_OAUTH_CLIENT_ID=
# X_OAUTH_CLIENT_SECRET=
# NEXTAUTH_URL=https://tu-app.vercel.app
